msgstr "Lot {i} / {n} : fusionnant le résumé en continu…"

#: i18n/llm_catalog_review.py:382
msgid "Cancelled before final summary."
msgstr "Annulé avant résumé final."

#: i18n/llm_catalog_review.py:387
msgid "Generating final summary…"
msgstr "Génération de la conclusion finale…"

#: i18n/llm_catalog_review.py:397
msgid ""
"Final summary failed: {err}\n"
"\n"
"Last rolling notes:\n"
"\n"
"{notes}"
msgstr ""
"Échec de la synthèse finale : {err}\n"
"\n"
"Dernières notes :\n"
"\n"
"{notes}"

#: i18n/llm_catalog_review.py:407
msgid ""
"(Empty final response; see rolling notes below.)\n"
"\n"
msgstr ""
"(Réponse finale vide ; voir les notes ci-dessous.)\n"
"\n"

