msgstr "Batch {i} / {n}: combinazione del sommaro in movimento…"

#: i18n/llm_catalog_review.py:382
msgid "Cancelled before final summary."
msgstr "Annullato prima del riassunto finale."

#: i18n/llm_catalog_review.py:387
msgid "Generating final summary…"
msgstr "Generazione della sommarizzazione finale…"

#: i18n/llm_catalog_review.py:397
msgid ""
"Final summary failed: {err}\n"
"\n"
"Last rolling notes:\n"
"\n"
"{notes}"
msgstr ""
"Errore durante il riepilogo finale: {err}\n"
"\n"
"Ultime note di aggiornamento:\n"
"\n"
"{notes}"

#: i18n/llm_catalog_review.py:407
msgid ""
"(Empty final response; see rolling notes below.)\n"
"\n"
msgstr ""
"(Risposta finale vuota; vedi le note in corso d'aggiornamento qui sotto.)\n"
"\n"

