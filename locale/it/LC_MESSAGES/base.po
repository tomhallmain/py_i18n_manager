#: ui/translation_windows/translation_quality_review_window.py:230
#: ui/translation_windows/translation_quality_review_window.py:745
#: ui/translation_windows/translation_quality_review_window.py:751
msgid "LLM review"
msgstr "Revisione del LLM"

#: ui/translation_windows/translation_quality_review_window.py:238
msgid ""
"Built-in checks: non-Latin-script locales with Latin words/runs and a "
"separate mixed-script Latin-leakage signal; translations identical to the "
"default locale or to other non-default locales; advisory check for trailing "
"sentence-stop mismatches vs. the default (extra, missing, or wrong stop for "
"the locale); quote-character style mismatches vs. the locale's expected "
"style (project setting, else a built-in per-language default, else the "
"locale's own dominant style in the catalog). Each finding is one row per "
"key, with all affected locales listed in Locales. Respects project "
"exclusions and ignore patterns. (English-ratio heuristic reserved.)"
msgstr ""
"Controlli integrati: locale con scrittura non latina con parole/sequenze "
"latine e un segnale separato di perdita latina in scrittura mista; "
"traduzioni identiche al locale predefinito o ad altri locale non "
"predefiniti; controllo consultivo di segni di fine frase diversi dal "
"predefinito (extra, mancante o errato per il locale); disallineamenti di "
"stile delle virgolette rispetto allo stile atteso del locale (impostazione "
"progetto, altrimenti predefinito integrato per lingua, altrimenti stile "
"dominante del locale nel catalogo). Ogni risultato è una riga per chiave, "
"con tutti i locale interessati in Locales. Rispetta esclusioni di progetto e"
" pattern di ignorare. (Euristica del rapporto inglese riservata.)"

