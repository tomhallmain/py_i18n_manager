msgstr ""

#: i18n/llm_catalog_review.py:154
msgid ""
"Output ONLY the bullet list for UPDATED_STATE, with a short \"CarryForward:\" line at the end listing msgid/locale "
"pairs to watch in later batches (or \"none\")."
msgstr ""

