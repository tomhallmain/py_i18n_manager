#: ui/llm_settings_dialog.py:34
msgid "LLM Translation Settings"
msgstr "Configuraciones de traducción del LLM"

#: ui/llm_settings_dialog.py:51
msgid ""
"Configure the prompt template used when translating with LLM.\n"
"Use the variables below to customize how translation requests are formatted."
msgstr ""
"Configurar la plantilla de prompt utilizada durante la traducción con un modelo de lenguaje grande (LLM).\n"
"Utilice las variables siguientes para personalizar cómo se formatean las solicitudes de traducción."

#: ui/llm_settings_dialog.py:58
msgid "Available Variables"
msgstr "Variables disponibles"

#: ui/llm_settings_dialog.py:69
msgid ""
"<i>Note: To include literal braces in the output, use double braces: {{{{ or"
" }}}}</i>"
msgstr ""
"<i>Nota: Para incluir llaves literales en la salida, utilice llaves dobles: "
"{{{{ o }}}}</i>"

#: ui/llm_settings_dialog.py:78
msgid "Prompt Template"
msgstr "Plantilla de_prompt"

#: ui/llm_settings_dialog.py:84
msgid "Enter your prompt template here..."
msgstr "Introduzca su plantilla de prompt aquí..."

#: ui/llm_settings_dialog.py:91
msgid "CJK Response Filtering"
msgstr "Filtrado deRespuestas CJK"

#: ui/llm_settings_dialog.py:95
msgid ""
"Reject LLM responses with high CJK character ratio for non-CJK target locales.\n"
"CJK target locales always bypass this filter."
msgstr ""
"Rechazar respuestas LLM con una alta proporción de caracteres CJK para locales de destino que no sean CJK.\n"
"Los locales de destino CJK siempre omiten este filtro."

#: ui/llm_settings_dialog.py:102
msgid "Reject threshold:"
msgstr "Umbral de rechazo:"

#: ui/llm_settings_dialog.py:107
msgid ""
"If CJK characters exceed this percentage, the response is rejected for non-"
"CJK locales."
msgstr ""
"Si los caracteres CJK superan este porcentaje, la respuesta se rechaza para "
"los entornos no CJK."

#: ui/llm_settings_dialog.py:115
msgid "Preview (Example Output)"
msgstr "Vista previa (Salida de ejemplo)"

#: ui/llm_settings_dialog.py:130
msgid "Save as project-specific override (only for this project)"
msgstr ""
"Guardar como sobrescripción específica del proyecto (solo para este "
"proyecto)"

#: ui/llm_settings_dialog.py:133
msgid ""
"If checked, this template will only be used for the current project.\n"
"If unchecked, it will be saved as the global default for all projects."
msgstr ""
"Si está marcada, esta plantilla solo se utilizará para el proyecto actual.\n"
"Si no está marcada, se guardará como valor predeterminado global para todos los proyectos."

#: ui/llm_settings_dialog.py:143 ui/llm_settings_dialog.py:218
msgid "Reset to Default"
msgstr "Reiniciar a la configuración por defecto"

#: ui/llm_settings_dialog.py:148 ui/llm_settings_dialog.py:235
msgid "Clear Project Override"
msgstr "Borrar Overrides del Proyecto"

#: ui/llm_settings_dialog.py:150
msgid "Remove project-specific template and use global default"
msgstr ""
"Eliminar la plantilla específica del proyecto y usar la plantilla por "
"defecto global"

#: ui/llm_settings_dialog.py:155
msgid "Save"
msgstr "Guardar"

#: ui/llm_settings_dialog.py:219
msgid "Are you sure you want to reset the template to the default?"
msgstr ""
"¿Estás seguro de que quieres reiniciar la plantilla a su configuración por "
"defecto?"

#: ui/llm_settings_dialog.py:236
msgid ""
"Are you sure you want to remove the project-specific template?\n"
"The global default will be used instead."
msgstr ""
"¿Estás seguro de que quieres eliminar la plantilla específica del proyecto?\n"
"Se usará la plantilla global predeterminada en su lugar."

#: ui/llm_settings_dialog.py:260
msgid "Project override cleared. Using global default template."
msgstr ""
"Sobrescripción del proyecto limpiada. Utilizando plantilla global "
"predeterminada."

#: ui/llm_settings_dialog.py:266
msgid "Failed to clear project override."
msgstr "No se pudo eliminar la sobreescritura del proyecto."

#: ui/llm_settings_dialog.py:277
msgid "Invalid Template"
msgstr "Plantilla Inválida"

#: ui/llm_settings_dialog.py:278
msgid "The template cannot be empty."
msgstr "La plantilla no puede estar vacía."

#: ui/llm_settings_dialog.py:289
msgid "Missing Variables"
msgstr "Variables ausentes"

#: ui/llm_settings_dialog.py:290
msgid ""
"The template is missing recommended variables: {vars}\n"
"\n"
"This may cause translation issues. Save anyway?"
msgstr ""
"La plantilla no contiene las variables recomendadas: {vars}\n"
"\n"
"Esto puede causar problemas de traducción. ¿Guardar de todos modos?"

