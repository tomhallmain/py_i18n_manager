msgid "LLM review"
msgstr "Revisión de LLM"

#: ui/translation_quality_review_window.py:175
msgid ""
"Built-in checks: non-Latin-script locales with Latin words/runs and a "
"separate mixed-script Latin-leakage signal; translations identical to the "
"default locale or to other non-default locales (one row per key, with "
"affected locales in Notes); advisory check for trailing sentence-stop "
"mismatches vs. the default (extra, missing, or wrong stop for the locale). "
"Respects project exclusions and ignore patterns. (English-ratio heuristic "
"reserved.)"
msgstr ""
"Comprobaciones integradas: configuraciones regionales con alfabeto no latino"
" que contengan palabras o secuencias en latín, y una señal independiente de "
"«filtración de caracteres latinos» en alfabetos mixtos; traducciones "
"idénticas a la configuración regional predeterminada o a otras "
"configuraciones regionales no predeterminadas (una fila por clave, con las "
"configuraciones regionales afectadas indicadas en las Notas); comprobación "
"indicativa de discrepancias en los caracteres de fin de frase al final de la"
" línea con respecto a la configuración predeterminada (caracteres de fin de "
"frase adicionales, faltantes o incorrectos para la configuración regional). "
"Respeta las exclusiones del proyecto y los patrones de ignorado. (Heurística"
" de proporción de inglés reservada.)"

