msgstr "Lote {i} / {n}: mezcla de resumen móvil…"

#: i18n/llm_catalog_review.py:320
msgid "Cancelled before final summary."
msgstr "Anulado antes del resumen final."

#: i18n/llm_catalog_review.py:325
msgid "Generating final summary…"
msgstr "Generando resumen final..."

#: i18n/llm_catalog_review.py:333
