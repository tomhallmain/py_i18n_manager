msgstr "Batch {i} / {n}: Kombinieren der laufenden Zusammenfassung…"

#: i18n/llm_catalog_review.py:324
msgid "Cancelled before final summary."
msgstr "Storniert vor der endgültigen Zusammenfassung."

#: i18n/llm_catalog_review.py:329
msgid "Generating final summary…"
msgstr "Generiere endgültigen Zusammenfassung…"

#: i18n/llm_catalog_review.py:337
msgid ""
"Final summary failed: {err}\n"
"\n"
"Last rolling notes:\n"
"\n"
"{notes}"
msgstr ""
"Die abschließende Zusammenfassung ist fehlgeschlagen: {err}\n"
"\n"
"Letzte fortlaufende Notizen:\n"
"\n"
"{notes}"

#: i18n/llm_catalog_review.py:347
